# ── OS & editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.iml
.vscode/

# ── Zephir compiler ───────────────────────────────────────────────────────────
# Cache and temp output; the generated ext/ C source is committed intentionally.
.zephir/
.temp/
zephir.phar
zephir-*.phar

# ── Composer / PHP tooling ────────────────────────────────────────────────────
vendor/
composer.lock

# ── IDE stubs (generated by `zephir stubs`) ──────────────────────────────────
# Intentionally committed so Packagist/PIE users and IDEs get autocomplete
# without having to re-run Zephir. Regenerate with `zephir stubs`.

# ── ext/ build artifacts ──────────────────────────────────────────────────────
# The C source files, config.m4, config.w32, and kernel/ are committed.
# Everything below is produced by phpize / configure / make and must NOT be committed.
ext/Makefile
ext/Makefile.fragments
ext/Makefile.global
ext/Makefile.objects
ext/acinclude.m4
ext/aclocal.m4
ext/autom4te.cache/
ext/build/
ext/config.guess
ext/config.h
ext/config.h.in
ext/config.nice
ext/config.status
ext/config.sub
ext/configure
ext/configure.ac
ext/configure.in
ext/install-sh
ext/libtool
ext/ltmain.sh
ext/missing
ext/mkinstalldirs
ext/modules/
ext/run-tests.php
ext/.libs/

# ── Compiled object files (anywhere under ext/) ───────────────────────────────
*.o
*.lo
*.la
*.loT
*.dep
*.gch
*.dSYM

# ── Build logs ────────────────────────────────────────────────────────────────
build.log
*.log
